rules_version = '2';

// Security rules for the Merkaztech activity log (merkaztech-log.html / merkaztech-entry.html).
// Paste this into Firebase Console → Firestore Database → Rules, and click "Publish".
//
// Anyone with the site link can read the log (needed for the live view page to work
// without logging in). Only signed-in staff (see MERKAZTECH-SETUP.md) can add, edit
// or delete activities.
service cloud.firestore {
  match /databases/{database}/documents {
    match /activities/{activityId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
